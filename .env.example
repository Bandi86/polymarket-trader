# Polymarket Trader Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Authentication
# ===========================================
# JWT secret for session tokens - MUST be changed in production
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-secure-jwt-secret-here

# ===========================================
# Database
# ===========================================
# Path to SQLite database file (optional, defaults to data/polymarket_v2.db)
DATABASE_PATH=data/polymarket_v2.db

# ===========================================
# Server Configuration
# ===========================================
# Backend server port (optional, defaults to 3001)
# BACKEND_PORT=3001

# ===========================================
# Polymarket API (stored via settings UI, not here)
# ===========================================
# Polymarket credentials are stored encrypted in the database
# Use the Settings page in the UI to configure:
# - Polymarket API Key
# - Polymarket Private Key (for trading)
#
# DO NOT put Polymarket secrets in this file!